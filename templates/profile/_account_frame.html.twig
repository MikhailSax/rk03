{% set page_title = page_title|default('Личный кабинет') %}
{% set page_subtitle = page_subtitle|default('') %}
{% set show_verification_badge = show_verification_badge|default(false) %}

<section class="min-h-[calc(100dvh-6rem)] bg-[var(--color-bg)] pb-16 pt-8">
    <div class="u-wrap">

        {# breadcrumb + page header — светлый, без градиента #}
        <div class="mb-8" data-reveal>
            <nav class="text-[.72rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-muted)]"
                 aria-label="Навигация">
                <a href="{{ path('app_homepage') }}" class="transition hover:text-[var(--color-ink)]">Главная</a>
                <span class="mx-2 opacity-40">/</span>
                <span>Личный кабинет</span>
            </nav>

            <div class="mt-5 flex flex-wrap items-end justify-between gap-4">
                <div>
                    <h1 class="text-[clamp(1.6rem,3.5vw,2.4rem)] font-extrabold tracking-tight">{{ page_title }}</h1>
                    {% if page_subtitle %}
                        <p class="mt-1.5 max-w-xl text-[var(--color-muted)]">{{ page_subtitle }}</p>
                    {% endif %}
                </div>

                {% if user is defined %}
                    <div class="flex flex-wrap items-center gap-2">
                        {# аватар-инициал #}
                        <span
                            class="grid h-10 w-10 shrink-0 place-items-center rounded-full font-[var(--font-display)] text-sm font-bold text-white"
                            style="background:var(--grad)">
                            {{ (user.firstName ?? 'U')|first|upper }}
                        </span>
                        <div class="text-sm">
                            <p class="font-semibold leading-tight">{{ user.firstName }} {{ user.lastName }}</p>
                            <p class="text-[.78rem] text-[var(--color-muted)]">{{ user.userIdentifier }}</p>
                        </div>
                        {% if show_verification_badge %}
                            <span class="u-pill {{ user.isVerified ? 'u-pill--free' : 'u-pill--hold' }}">
                                {{ user.isVerified ? '✓ Email подтверждён' : '! Email не подтверждён' }}
                            </span>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

        {# флеши #}
        <div class="mb-6">
            {% include 'components/_account_flashes.html.twig' with { keys: ['success', 'error'] } only %}
        </div>

        {# layout: sidebar + main #}
        <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:gap-8">

            {# sidebar nav #}
            <aside class="shrink-0 lg:sticky lg:top-28 lg:w-56">
                {% include 'profile/_tabs.html.twig' %}
            </aside>

            {# content #}
            <div class="min-w-0 flex-1">
                {% block account_main %}{% endblock %}
            </div>
        </div>

    </div>
</section>
