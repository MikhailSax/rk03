{% extends 'base.html.twig' %}

{% block title %}Личный кабинет — РК03{% endblock %}

{% block body %}
    {% embed 'profile/_account_frame.html.twig' with {
        page_title: 'Личный кабинет',
        page_subtitle: 'Управляйте данными, паролем и просматривайте активность.',
        show_verification_badge: true,
    } %}
        {% block account_main %}
            <div class="grid gap-6 xl:grid-cols-[1fr_300px]">

                {# форма #}
                <div>{% include 'profile/_form.html.twig' with { profileForm: profileForm } %}</div>

                {# правая колонка #}
                <div class="flex flex-col gap-5">

                    {# сводка #}
                    <div class="u-card p-5">
                        <p class="mb-4 text-[.66rem] font-bold uppercase tracking-[0.2em] text-[var(--color-muted)]">
                            Сводка</p>
                        <div class="space-y-3 text-sm">
                            <div class="flex items-center gap-3">
                                <span
                                    class="grid h-9 w-9 shrink-0 place-items-center rounded-full font-[var(--font-display)] text-sm font-bold text-white"
                                    style="background:var(--grad)">
                                    {{ (user.firstName ?? 'U')|first|upper }}
                                </span>
                                <div class="min-w-0">
                                    <p class="truncate font-semibold">{{ user.firstName ?: '—' }} {{ user.lastName ?: '' }}</p>
                                    <p class="truncate text-xs text-[var(--color-muted)]">{{ user.userIdentifier }}</p>
                                </div>
                            </div>
                            <div class="border-t border-[rgba(13,19,32,.07)] pt-3 space-y-2">
                                <div class="flex justify-between text-xs">
                                    <span class="text-[var(--color-muted)]">Телефон</span>
                                    <span class="font-medium">{{ user.phone ?: '—' }}</span>
                                </div>
                                <div class="flex justify-between text-xs">
                                    <span class="text-[var(--color-muted)]">Email</span>
                                    <span
                                        class="u-pill !text-[10px] {{ user.isVerified ? 'u-pill--free' : 'u-pill--hold' }}">
                                        {{ user.isVerified ? 'Подтверждён' : 'Не подтверждён' }}
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# быстрые действия #}
                    <div class="u-card p-5">
                        <p class="mb-4 text-[.66rem] font-bold uppercase tracking-[0.2em] text-[var(--color-muted)]">
                            Быстрые действия</p>
                        <div class="flex flex-col gap-2">
                            <a href="{{ path('profile.orders') }}"
                               class="flex items-center justify-between rounded-[var(--radius-soft)] border border-[rgba(13,19,32,.08)] bg-[var(--color-bg)] px-4 py-3 text-sm font-semibold transition hover:border-[var(--color-blue)] hover:bg-[var(--color-tint-blue)] hover:text-[var(--color-blue)]">
                                <span> Заказы и активность</span><span>→</span>
                            </a>
                            <a href="{{ path('app_cart') }}"
                               class="flex items-center justify-between rounded-[var(--radius-soft)] border border-[rgba(13,19,32,.08)] bg-[var(--color-bg)] px-4 py-3 text-sm font-semibold transition hover:border-[var(--color-blue)] hover:bg-[var(--color-tint-blue)] hover:text-[var(--color-blue)]">
                                <span> Корзина</span><span>→</span>
                            </a>
                            <a href="{{ path('app_map_app') }}"
                               class="flex items-center justify-between rounded-[var(--radius-soft)] border border-[rgba(13,19,32,.08)] bg-[var(--color-bg)] px-4 py-3 text-sm font-semibold transition hover:border-[var(--color-blue)] hover:bg-[var(--color-tint-blue)] hover:text-[var(--color-blue)]">
                                <span>Карта конструкций</span><span>→</span>
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        {% endblock %}
    {% endembed %}
{% endblock %}
