<nav class="flex flex-row gap-1 lg:flex-col" aria-label="Разделы кабинета">
    {% set tabs = [
        { route: 'profile',        icon: '👤', label: 'Профиль',              sub: 'Данные и пароль' },
        { route: 'profile.orders', icon: '📋', label: 'Активность и заказы',  sub: 'История' }
    ] %}
    {% for t in tabs %}
        {% set active = app.request.attributes.get('_route') == t.route %}
        <a href="{{ path(t.route) }}"
           class="group flex items-center gap-3 rounded-[var(--radius-soft)] px-4 py-3 text-sm transition
           {{ active
           ? 'bg-[var(--color-blue)] text-white shadow-[0_8px_20px_-8px_rgba(42,75,247,.65)]'
           : 'text-[var(--color-ink)] hover:bg-[var(--color-tint-blue)] hover:text-[var(--color-blue)]' }}">
            <span class="text-base leading-none">{{ t.icon }}</span>
            <span class="min-w-0">
                <span class="block font-bold leading-tight">{{ t.label }}</span>
                <span
                    class="block text-[.72rem] {{ active ? 'text-white/70' : 'text-[var(--color-muted)]' }}">{{ t.sub }}</span>
            </span>
        </a>
    {% endfor %}
</nav>
