{% extends 'base.html.twig' %}

{% block title %}Активность — личный кабинет{% endblock %}

{% block body %}
    {% embed 'profile/_account_frame.html.twig' with {
        page_title: 'Активность и заказы',
        page_subtitle: 'Заказы из личного кабинета и заявки, оставленные с карты по вашему телефону.',
        show_verification_badge: false,
    } %}
        {% block account_main %}
            <div class="space-y-8">
                {# заказы #}
                <div class="u-card p-6 sm:p-8">
                    <h2 class="text-sm font-bold uppercase tracking-[0.14em] text-[var(--color-blue)]">Мои заказы</h2>
                    <p class="mt-2 text-sm text-[var(--color-muted)]">Заказы привязаны к вашему аккаунту при оформлении на сайте.</p>

                    {% if userOrders is empty %}
                        <div class="mt-6 rounded-[var(--radius-soft)] border border-[rgba(13,19,32,.08)] bg-[var(--color-bg)] p-5">
                            <p class="text-sm text-[var(--color-muted)]">У вас пока нет заказов.</p>
                            <div class="mt-4 flex flex-wrap gap-3">
                                <a href="{{ path('app_map_app') }}" class="u-btn u-btn--soft">Подобрать конструкции</a>
                                <a href="{{ path('app_cart') }}" class="u-btn u-btn--blue">Корзина</a>
                            </div>
                        </div>
                    {% else %}
                        <p class="mt-4 text-sm text-[var(--color-muted)]">Всего заказов: <span class="font-semibold text-[var(--color-ink)]">{{ userOrders|length }}</span></p>
                        <div class="mt-6 overflow-hidden rounded-[var(--radius-soft)] border border-[rgba(13,19,32,.08)]">
                            <div class="overflow-x-auto">
                                <table class="min-w-full divide-y divide-[rgba(13,19,32,.08)] text-sm">
                                    <thead class="bg-[var(--color-bg-2)] text-left text-[10px] font-bold uppercase tracking-[0.1em] text-[var(--color-muted)]">
                                    <tr><th class="px-4 py-3">№</th><th class="px-4 py-3">Дата</th><th class="px-4 py-3">Статус</th><th class="px-4 py-3">Позиции</th><th class="px-4 py-3">Бронь до</th></tr>
                                    </thead>
                                    <tbody class="divide-y divide-[rgba(13,19,32,.06)]">
                                    {% for order in userOrders %}
                                        {% set status_label = order.status == 'paid' ? 'Оплачен' : (order.status == 'cancelled' ? 'Отменён' : 'Ожидает оплаты') %}
                                        {% set status_pill = order.status == 'paid' ? 'u-pill--free' : (order.status == 'cancelled' ? '' : 'u-pill--hold') %}
                                        <tr class="transition hover:bg-[var(--color-bg)]">
                                            <td class="whitespace-nowrap px-4 py-3 font-semibold">#{{ order.id }}</td>
                                            <td class="whitespace-nowrap px-4 py-3 text-[var(--color-muted)]">{{ order.createdAt ? order.createdAt|date('d.m.Y H:i') : '—' }}</td>
                                            <td class="px-4 py-3"><span class="u-pill {{ status_pill }}" {{ status_pill ? '' : 'style="background:var(--color-bg-2);color:var(--color-muted)"' }}>{{ status_label }}</span></td>
                                            <td class="px-4 py-3">{{ order.items|length }}</td>
                                            <td class="whitespace-nowrap px-4 py-3 text-[var(--color-muted)]">
                                                {% if order.status == 'pending' and order.reservedUntil %}{{ order.reservedUntil|date('d.m.Y H:i') }}{% else %}—{% endif %}
                                            </td>
                                        </tr>
                                        {% if order.items is not empty %}
                                            <tr class="bg-[var(--color-bg)] text-xs text-[var(--color-muted)]">
                                                <td colspan="5" class="px-4 py-3">
                                                    <ul class="flex flex-wrap gap-x-4 gap-y-1">
                                                        {% for item in order.items %}
                                                            <li>
                                                                {% set ad = item.advertisement %}
                                                                {% if ad %}
                                                                    <a href="{{ path('app_catalog_construction', { id: ad.id }) }}" class="font-medium text-[var(--color-blue)] underline-offset-2 hover:underline">{{ ad.placeNumber ?: ad.code ?: ('#' ~ ad.id) }}</a>
                                                                {% else %}—{% endif %}
                                                                · сторона {{ item.sideCode }} · {{ item.startDate ? item.startDate|date('d.m.Y') : '—' }} — {{ item.endDate ? item.endDate|date('d.m.Y') : '—' }}
                                                            </li>
                                                        {% endfor %}
                                                    </ul>
                                                </td>
                                            </tr>
                                        {% endif %}
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    {% endif %}
                </div>

                {# заявки с карты #}
                <div class="u-card p-6 sm:p-8">
                    <h2 class="text-sm font-bold uppercase tracking-[0.14em] text-[var(--color-blue)]">Заявки с карты</h2>
                    <p class="mt-2 text-sm text-[var(--color-muted)]">Заявки ищутся по номеру телефона из профиля.</p>

                    {% if user.phone is empty %}
                        <div class="mt-6 rounded-[var(--radius-soft)] border border-[var(--color-tint-amber)] bg-[var(--color-tint-amber)] p-5">
                            <p class="text-sm text-[var(--color-hold)]">Добавьте телефон в профиле, чтобы мы могли найти связанные заявки.</p>
                            <a href="{{ path('profile') }}" class="u-btn u-btn--soft mt-3">Заполнить телефон</a>
                        </div>
                    {% elseif userRequests is empty %}
                        <div class="mt-6 rounded-[var(--radius-soft)] border border-[rgba(13,19,32,.08)] bg-[var(--color-bg)] p-5">
                            <p class="text-sm text-[var(--color-muted)]">По вашему номеру телефона заявок пока нет.</p>
                            <a href="{{ path('app_map_app') }}" class="u-btn u-btn--soft mt-3">Открыть карту конструкций</a>
                        </div>
                    {% else %}
                        <p class="mt-4 text-sm text-[var(--color-muted)]">Найдено заявок: <span class="font-semibold text-[var(--color-ink)]">{{ userRequests|length }}</span>.</p>
                        <div class="mt-6 overflow-hidden rounded-[var(--radius-soft)] border border-[rgba(13,19,32,.08)]">
                            <div class="overflow-x-auto">
                                <table class="min-w-full divide-y divide-[rgba(13,19,32,.08)] text-sm">
                                    <thead class="bg-[var(--color-bg-2)] text-left text-[10px] font-bold uppercase tracking-[0.1em] text-[var(--color-muted)]">
                                    <tr><th class="px-4 py-3">Дата</th><th class="px-4 py-3">Конструкция</th><th class="px-4 py-3">Сторона</th><th class="px-4 py-3">Комментарий</th></tr>
                                    </thead>
                                    <tbody class="divide-y divide-[rgba(13,19,32,.06)]">
                                    {% for request in userRequests %}
                                        <tr class="transition hover:bg-[var(--color-bg)]">
                                            <td class="whitespace-nowrap px-4 py-3">{{ request.createdAt ? request.createdAt|date('d.m.Y H:i') : '—' }}</td>
                                            <td class="px-4 py-3">{{ request.advertisement ? (request.advertisement.code ?: request.advertisement.placeNumber ?: ('#' ~ request.advertisement.id)) : '—' }}</td>
                                            <td class="px-4 py-3">{{ request.sideCode ?: '—' }}</td>
                                            <td class="px-4 py-3">{{ request.comment ?: '—' }}</td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endblock %}
    {% endembed %}
{% endblock %}
