{% import 'macros/account_ui.html.twig' as ui %}
<section class="max-w-3xl mx-auto">
    {{ form_start(profileForm, { attr: { class: 'space-y-10 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm sm:p-8' } }) }}

    {% if not profileForm.vars.valid %}
        <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
            Пожалуйста, проверьте поля формы и исправьте ошибки.
        </div>
    {% endif %}

    <div>
        <div class="mb-6 flex items-center justify-between border-b border-gray-100 pb-3">
            <h2 class="home-display text-sm font-bold uppercase tracking-[0.16em] text-[#05299E]">
                Личная информация
            </h2>
            <span class="rounded-full border border-[#05299E]/20 bg-[#05299E]/5 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-[#05299E]">
                Профиль
            </span>
        </div>
        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
            <div>
                {{ form_label(profileForm.first_name, null, { label_attr: { class: ui.label_class() } }) }}
                {{ form_widget(profileForm.first_name, { attr: { class: ui.input_class() ~ ' text-sm' } }) }}
                <div class="mt-1 text-sm text-red-600">{{ form_errors(profileForm.first_name) }}</div>
            </div>

            <div>
                {{ form_label(profileForm.last_name, null, { label_attr: { class: ui.label_class() } }) }}
                {{ form_widget(profileForm.last_name, { attr: { class: ui.input_class() ~ ' text-sm' } }) }}
                <div class="mt-1 text-sm text-red-600">{{ form_errors(profileForm.last_name) }}</div>
            </div>

            <div>
                {{ form_label(profileForm.phone, null, { label_attr: { class: ui.label_class() } }) }}
                {{ form_widget(profileForm.phone, { attr: { class: ui.input_class() ~ ' text-sm' } }) }}
                <div class="mt-1 text-sm text-red-600">{{ form_errors(profileForm.phone) }}</div>
            </div>

            <div>
                {{ form_label(profileForm.email, null, { label_attr: { class: ui.label_class() } }) }}
                {{ form_widget(profileForm.email, { attr: { class: ui.input_class() ~ ' text-sm' } }) }}
                <div class="mt-1 text-sm text-red-600">{{ form_errors(profileForm.email) }}</div>
            </div>
        </div>
    </div>

    <div class="rounded-xl border border-gray-100 bg-[#f8f9fb] p-5 text-xs leading-relaxed text-gray-600">
        Контактные данные используются для подтверждения заказов и обратной связи.
        Следите, чтобы телефон был актуален — по нему привязываются заявки с карты.
    </div>

    <div class="border-t border-gray-100 pt-10">
        <h2 class="home-display border-b border-gray-100 pb-3 text-sm font-bold uppercase tracking-[0.16em] text-[#05299E]">
            Смена пароля
        </h2>
        <p class="mt-4 text-sm text-gray-600">Заполняйте оба поля только если хотите изменить пароль.</p>
        <div class="mt-6 grid grid-cols-1 gap-5 md:grid-cols-2">
            <div>
                {{ form_label(profileForm.currentPassword, null, { label_attr: { class: ui.label_class() } }) }}
                {{ form_widget(profileForm.currentPassword, { attr: { class: ui.input_class() ~ ' text-sm' } }) }}
                <div class="mt-1 text-sm text-red-600">{{ form_errors(profileForm.currentPassword) }}</div>
            </div>

            <div>
                {{ form_label(profileForm.newPassword, null, { label_attr: { class: ui.label_class() } }) }}
                {{ form_widget(profileForm.newPassword, { attr: { class: ui.input_class() ~ ' text-sm' } }) }}
                <div class="mt-1 text-sm text-red-600">{{ form_errors(profileForm.newPassword) }}</div>
            </div>
        </div>
    </div>

    <div class="flex flex-wrap items-center gap-3 border-t border-gray-100 pt-8">
        <button type="submit" class="home-display inline-flex items-center rounded-xl bg-[#05299E] px-6 py-3 text-xs font-semibold uppercase tracking-[0.12em] text-white shadow-sm transition hover:bg-[#041d6b] focus:outline-none focus:ring-2 focus:ring-[#05299E]/35 focus:ring-offset-2">
            Сохранить изменения
        </button>
        <a href="{{ path('profile.orders') }}" class="home-display inline-flex items-center rounded-xl border border-gray-300 bg-white px-5 py-3 text-xs font-semibold uppercase tracking-[0.1em] text-gray-700 transition hover:border-[#05299E]/40 hover:text-[#05299E]">
            Активность и заказы
        </a>
    </div>
    {{ form_end(profileForm) }}
</section>
