{% import 'macros/account_ui.html.twig' as ui %}

{{ form_start(profileForm, { attr: { class: 'space-y-8' } }) }}

{% if not profileForm.vars.valid %}
    <div
        class="rounded-[var(--radius-soft)] border border-[var(--color-tint-coral)] bg-[var(--color-tint-coral)] px-4 py-3 text-sm text-[var(--color-busy)]">
        Проверьте поля формы и исправьте ошибки.
    </div>
{% endif %}

{# Личная информация #}
<div class="u-card p-6 sm:p-8">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <p class="text-[.66rem] font-bold uppercase tracking-[0.2em] text-[var(--color-blue)]">Шаг 1</p>
            <h2 class="mt-1 text-lg font-extrabold tracking-tight">Личная информация</h2>
        </div>
        <span class="u-pill" style="background:var(--color-tint-blue);color:var(--color-blue)">Профиль</span>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
        {% for f in [profileForm.first_name, profileForm.last_name] %}
            <div>
                {{ form_label(f, null, { label_attr: { class: ui.label_class() } }) }}
                {{ form_widget(f, { attr: { class: ui.input_class() } }) }}
                <div class="mt-1 text-xs text-[var(--color-busy)]">{{ form_errors(f) }}</div>
            </div>
        {% endfor %}
        {% for f in [profileForm.phone, profileForm.email] %}
            <div>
                {{ form_label(f, null, { label_attr: { class: ui.label_class() } }) }}
                {{ form_widget(f, { attr: { class: ui.input_class() } }) }}
                <div class="mt-1 text-xs text-[var(--color-busy)]">{{ form_errors(f) }}</div>
            </div>
        {% endfor %}
    </div>

    <p class="mt-5 rounded-[var(--radius-xs,8px)] border border-[rgba(13,19,32,.07)] bg-[var(--color-bg)] px-4 py-3 text-[.8rem] leading-relaxed text-[var(--color-muted)]">
        Контактные данные нужны для подтверждения заказов. Телефон привязывает заявки с карты к вашему аккаунту.
    </p>
</div>

{# Смена пароля #}
<div class="u-card p-6 sm:p-8">
    <div class="mb-6">
        <p class="text-[.66rem] font-bold uppercase tracking-[0.2em] text-[var(--color-muted)]">Шаг 2 ·
            необязательно</p>
        <h2 class="mt-1 text-lg font-extrabold tracking-tight">Смена пароля</h2>
        <p class="mt-1 text-sm text-[var(--color-muted)]">Заполняйте только если хотите изменить пароль.</p>
    </div>
    <div class="grid gap-5 sm:grid-cols-2">
        {% for f in [profileForm.currentPassword, profileForm.newPassword] %}
            <div>
                {{ form_label(f, null, { label_attr: { class: ui.label_class() } }) }}
                {{ form_widget(f, { attr: { class: ui.input_class() } }) }}
                <div class="mt-1 text-xs text-[var(--color-busy)]">{{ form_errors(f) }}</div>
            </div>
        {% endfor %}
    </div>
</div>

{# action #}
<div class="flex flex-wrap gap-3">
    <button type="submit" class="u-btn u-btn--blue">Сохранить изменения</button>
    <a href="{{ path('profile.orders') }}" class="u-btn u-btn--soft">Активность и заказы</a>
</div>

{{ form_end(profileForm) }}
