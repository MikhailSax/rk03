{# =====================================================================
   Единые классы форм/кнопок (Фаза 1) под новую систему.
   Переодевает вход, регистрацию и кабинет без правки самих шаблонов —
   они уже зовут эти макросы.
   ===================================================================== #}

{% macro input_class() -%}
    u-input text-sm
{%- endmacro %}

{% macro label_class() -%}
    u-field-label
{%- endmacro %}

{% macro btn_primary_full() -%}
    u-btn u-btn--blue w-full justify-center
{%- endmacro %}

{% macro link_accent_class() -%}
    font-semibold text-[var(--color-blue)] transition hover:text-[var(--color-blue-deep)]
{%- endmacro %}

{% macro auth_title_class() -%}
    home-display text-2xl font-bold tracking-tight text-[var(--color-ink)] sm:text-[1.65rem]
{%- endmacro %}

{% macro auth_subtitle_class() -%}
    mt-2 text-sm text-[var(--color-muted)]
{%- endmacro %}
