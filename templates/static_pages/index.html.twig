{% extends 'base.html.twig' %}

{% block title %}РК03 — наружная реклама{% endblock %}

{% block head_extra %}
    {% if home_preload_image is defined and home_preload_image %}
        <link rel="preload" as="image" href="{{ asset(home_preload_image) }}">
    {% endif %}
    {% if home_json_ld is defined %}
        <script
            type="application/ld+json">{{ home_json_ld|json_encode(constant('JSON_UNESCAPED_UNICODE'))|raw }}</script>
    {% endif %}

    {# Стили только для главной (page-scoped). Общие — в app.css. #}
    <style>
        .h-blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(110px);
            z-index: -1;
            pointer-events: none
        }

        .h-blob--a {
            width: 520px;
            height: 520px;
            background: var(--color-tint-blue);
            top: -120px;
            right: -40px;
            opacity: .9
        }

        .h-blob--b {
            width: 380px;
            height: 380px;
            background: var(--color-tint-coral);
            bottom: -120px;
            left: -60px;
            opacity: .7
        }

        .h-h1 {
            font-family: var(--font-display);
            font-weight: 700;
            letter-spacing: -.02em;
            line-height: 1.04;
            font-size: clamp(2.4rem, 5.6vw, 4.4rem)
        }

        .h-h1 .line {
            display: block;
            overflow: hidden
        }

        .h-h1 .line > span {
            display: block;
            transform: translateY(108%);
            animation: h-rise .9s cubic-bezier(.16, 1, .3, 1) forwards
        }

        .h-h1 .line:nth-child(1) > span {
            animation-delay: .05s
        }

        .h-h1 .line:nth-child(2) > span {
            animation-delay: .16s
        }

        .h-h1 .line:nth-child(3) > span {
            animation-delay: .27s
        }

        @keyframes h-rise {
            to {
                transform: translateY(0)
            }
        }

        .cyc {
            position: relative;
            display: inline-grid;
            vertical-align: bottom
        }

        .cyc > span {
            grid-area: 1/1;
            opacity: 0;
            transform: translateY(28%);
            filter: blur(6px);
            white-space: nowrap;
            transition: opacity .5s, transform .5s, filter .5s;
            background: var(--grad);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent
        }

        .cyc > span.on {
            opacity: 1;
            transform: none;
            filter: none
        }

        /* hero панель-продукт */
        .h-panel {
            position: relative;
            border-radius: var(--radius-card);
            background: var(--color-card);
            box-shadow: var(--shadow-card);
            padding: 14px
        }

        .h-map {
            position: relative;
            border-radius: 18px;
            overflow: hidden;
            height: 300px;
            background: radial-gradient(ellipse 60% 60% at 35% 30%, rgba(42, 75, 247, .16), transparent 70%),
            radial-gradient(ellipse 50% 50% at 80% 75%, rgba(255, 106, 77, .12), transparent 70%), #EEF1FA
        }

        .h-map .road {
            position: absolute;
            background: rgba(13, 19, 32, .07)
        }

        .h-map .road.r1 {
            left: -10%;
            width: 120%;
            height: 8px;
            top: 42%;
            transform: rotate(-7deg)
        }

        .h-map .road.r2 {
            left: -10%;
            width: 120%;
            height: 5px;
            top: 70%;
            transform: rotate(-7deg)
        }

        .h-map .road.r3 {
            top: -10%;
            height: 120%;
            width: 6px;
            left: 55%;
            transform: rotate(5deg)
        }

        .h-pin {
            position: absolute;
            transform: translate(-50%, -100%);
            width: 22px;
            height: 22px
        }

        .h-pin i {
            display: block;
            width: 22px;
            height: 22px;
            border-radius: 50% 50% 50% 0;
            transform: rotate(-45deg);
            border: 2px solid #fff;
            box-shadow: 0 6px 14px -4px rgba(13, 19, 32, .4)
        }

        .h-pin.free i {
            background: var(--color-free)
        }

        .h-pin.busy i {
            background: var(--color-coral)
        }

        .h-pin.sel i {
            background: var(--color-blue);
            transform: rotate(-45deg) scale(1.25);
            box-shadow: 0 0 0 6px rgba(42, 75, 247, .25)
        }

        .h-mini {
            position: absolute;
            right: -10px;
            bottom: -18px;
            width: 230px;
            background: #fff;
            border-radius: 16px;
            box-shadow: var(--shadow-card);
            padding: 12px;
            animation: h-float 7s ease-in-out infinite;
            animation-delay: -2s
        }

        @keyframes h-float {
            0%, 100% {
                transform: translateY(0)
            }
            50% {
                transform: translateY(-10px)
            }
        }

        /* bento */
        .h-bento {
            display: grid;
            grid-template-columns:repeat(6, 1fr);
            gap: 18px
        }

        .fcard {
            position: relative;
            border-radius: var(--radius-card);
            overflow: hidden;
            padding: 24px;
            min-height: 280px;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            color: #fff;
            isolation: isolate;
            transition: transform .4s cubic-bezier(.16, 1, .3, 1), box-shadow .4s
        }

        .fcard:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-card)
        }

        .fcard--a {
            grid-column: span 4
        }

        .fcard--b {
            grid-column: span 2
        }

        .fcard--c {
            grid-column: span 2
        }

        .fcard--d {
            grid-column: span 4
        }

        .fcard__img {
            position: absolute;
            inset: 0;
            z-index: -2;
            background: center/cover;
            transform: scale(1.04);
            transition: transform .8s cubic-bezier(.16, 1, .3, 1)
        }

        .fcard::after {
            content: "";
            position: absolute;
            inset: 0;
            z-index: -1;
            background: linear-gradient(180deg, transparent 35%, rgba(8, 12, 28, .78) 100%)
        }

        .fcard:hover .fcard__img {
            transform: scale(1.1)
        }

        .fcard__tag {
            align-self: flex-start;
            font-weight: 700;
            font-size: .66rem;
            background: rgba(255, 255, 255, .16);
            backdrop-filter: blur(6px);
            border: 1px solid rgba(255, 255, 255, .25);
            padding: .4rem .7rem;
            border-radius: 999px;
            margin-bottom: auto
        }

        .fcard h3 {
            font-weight: 800;
            font-size: 1.5rem;
            letter-spacing: -.01em
        }

        .fcard p {
            margin-top: .5rem;
            font-size: .92rem;
            color: rgba(255, 255, 255, .82);
            max-width: 40ch
        }

        .fcard__link {
            margin-top: 1rem;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            font-weight: 700;
            font-size: .86rem
        }

        .fcard__link .arr {
            transition: transform .25s
        }

        .fcard:hover .fcard__link .arr {
            transform: translateX(4px)
        }

        /* steps */
        .h-step__n {
            width: 46px;
            height: 46px;
            border-radius: 14px;
            display: grid;
            place-items: center;
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 1.1rem;
            color: #fff;
            background: var(--grad)
        }

        .h-step:nth-child(2) .h-step__n {
            background: linear-gradient(135deg, #16299E, #2A4BF7)
        }

        .h-step:nth-child(3) .h-step__n {
            background: linear-gradient(135deg, #7C5CFF, #FF6A4D)
        }

        /* faq */
        .h-faq summary {
            list-style: none
        }

        .h-faq summary::-webkit-details-marker {
            display: none
        }

        .h-faq .pm {
            transition: transform .3s, background .3s, color .3s
        }

        .h-faq details[open] .pm {
            background: var(--color-blue);
            color: #fff;
            transform: rotate(45deg)
        }

        @media (max-width: 920px) {
            .h-bento {
                grid-template-columns:1fr
            }

            .fcard--a, .fcard--b, .fcard--c, .fcard--d {
                grid-column: span 1
            }
        }

        /* ticker */
        .ticker-wrap {
            overflow: hidden;
            position: relative;
            border-top: 1px solid rgba(13, 19, 32, .07);
            border-bottom: 1px solid rgba(13, 19, 32, .07);
            background: #fff;
            padding: 0
        }

        .ticker-wrap::before, .ticker-wrap::after {
            content: "";
            position: absolute;
            top: 0;
            bottom: 0;
            width: 80px;
            z-index: 2;
            pointer-events: none
        }

        .ticker-wrap::before {
            left: 0;
            background: linear-gradient(to right, #fff, transparent)
        }

        .ticker-wrap::after {
            right: 0;
            background: linear-gradient(to left, #fff, transparent)
        }

        .ticker-track {
            display: flex;
            width: max-content;
            animation: ticker-slide 32s linear infinite
        }

        .ticker-track:hover {
            animation-play-state: paused
        }

        .ticker-item {
            display: inline-flex;
            align-items: center;
            gap: .75rem;
            padding: .85rem 2rem;
            white-space: nowrap;
            font-size: .82rem;
            font-weight: 600;
            color: var(--color-muted)
        }

        .ticker-item .t-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--color-blue);
            opacity: .45;
            flex-shrink: 0
        }

        .ticker-item .t-pill {
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            padding: .25rem .7rem;
            border-radius: 999px
        }

        .ticker-item a {
            color: inherit;
            text-decoration: none;
            transition: color .2s
        }

        .ticker-item a:hover {
            color: var(--color-blue)
        }

        @keyframes ticker-slide {
            0% {
                transform: translateX(0)
            }
            100% {
                transform: translateX(-50%)
            }
        }

        @media (prefers-reduced-motion: reduce) {
            .ticker-track {
                animation: none
            }
        }
    </style>
{% endblock %}

{% block body %}
    {# HERO #}
    <section class="u-wrap" style="padding-top: 1.5rem; padding-bottom: 0;">
        <div class="hero-wrap">

            {# Левая панель — текст #}
            <div class="hero-left">
                <span class="u-eyebrow" style="margin-bottom:1.2rem;">Наружная реклама · Улан-Удэ и регион</span>

                <h1 class="h-h1 hero-h1">
                    <span class="line"><span>Ваш бренд —</span></span>
                    <span class="line"><span>в каждой точке</span></span>
                    <span class="line"><span>
                        <span class="cyc" data-cycler="города | района | трассы | проспекта"></span>
                    </span></span>
                </h1>

                <p class="hero-lead">
                    Живая карта конструкций: подбирайте площадки, смотрите занятость по датам и бронируйте в один клик —
                    от билборда до digital-экрана.
                </p>

                <div style="margin-top:1.75rem; display:flex; flex-wrap:wrap; gap:.75rem;">
                    <a href="{{ path('app_map_app') }}" class="u-btn u-btn--primary">Открыть карту <span
                            class="arr">→</span></a>
                    <a href="#formats" class="u-btn u-btn--soft">Смотреть форматы</a>
                </div>

                <div class="hero-stats">
                    <div>
                        <b class="home-display hero-stat-num" data-count="15">0</b>
                        <span class="hero-stat-label">лет на рынке OOH</span>
                    </div>
                    <div>
                        <b class="home-display hero-stat-num"><span data-count="345">0</span>%</b>
                        <span class="hero-stat-label">рост трафика после кампании</span>
                    </div>
                    <div>
                        <b class="home-display hero-stat-num" data-count="5">0</b>
                        <span class="hero-stat-label">дней до запуска</span>
                    </div>
                </div>
            </div>

            {# Правая панель — слайдер #}
            <div class="hero-right" id="hero-rhs">
                {% set hero_slides = [
                    { img: 'images/bilboard.jpg',        tag: 'Классика OOH',           title: 'Билборд 6×3 · ул. Ленина',   sub: 'Сторона A · по ходу потока · 42 000 ₽' },
                    { img: 'images/digital.png',          tag: 'Digital · 24/7',          title: 'Digital-экран · пр. Победы',  sub: 'Ротация каждые 8 секунд' },
                    { img: 'images/city.jpg',             tag: 'Сити-формат · Пешеходы', title: 'Сити-бокс · ул. Смолина',    sub: 'Подсветка 24/7 · от 18 000 ₽' },
                    { img: 'images/supersite-format.jpg', tag: 'Суперсайт · Охват',      title: 'Суперсайт · Трасса М55',     sub: 'Стороны A / B / C · по запросу' },
                ] %}
                {% for slide in hero_slides %}
                    <div class="hs" style="background-image:url('{{ asset(slide.img) }}');">
                        <div class="hs-overlay"></div>
                        <div class="hs-cap">
                            <p class="hs-cap-tag">{{ slide.tag }}</p>
                            <p class="hs-cap-title">{{ slide.title }}</p>
                            <p class="hs-cap-sub">{{ slide.sub }}</p>
                        </div>
                    </div>
                {% endfor %}
                <div id="hero-dots"></div>
                <div id="hero-pb"></div>
            </div>

        </div>
    </section>

    {# FORMATS #}
    <section class="u-section" id="formats">
        <div class="u-wrap">
            <div class="mb-12 max-w-[48ch]" data-reveal>
                <h2 class="u-sec-title">Форматы, которые <em class="u-grad not-italic">видно</em> за километр</h2>
                <p class="u-sec-lead">От крупногабаритных суперсайтов на трассах до световых сити-боксов у пешеходов.
                    Всё на одной карте — с ценой и занятостью.</p>
            </div>
            <div class="h-bento">
                <a href="{{ path('app_site_page', { path: 'media/billboards' }) }}" class="fcard fcard--a" data-reveal>
                    <div class="fcard__img"
                         style="background-image:url('{{ asset('images/supersite-format.jpg') }}')"></div>
                    <span class="fcard__tag">Максимальный охват</span>
                    <h3>Суперсайты</h3>
                    <p>Самый крупный формат — видно издалека. Шоссе, проспекты, парковки ТЦ. Стороны A / B / C по
                        направлению потока.</p>
                    <span class="fcard__link">На карте <span class="arr">→</span></span>
                </a>
                <a href="{{ path('app_site_page', { path: 'formats' }) }}" class="fcard fcard--b" data-reveal>
                    <div class="fcard__img"
                         style="background-image:url('{{ asset('uploads/main/digital.png') }}')"></div>
                    <span class="fcard__tag">Динамика 24/7</span>
                    <h3>Digital</h3>
                    <p>Ротация креативов по времени и триггерам.</p>
                    <span class="fcard__link">Подробнее <span class="arr">→</span></span>
                </a>
                <a href="{{ path('app_site_page', { path: 'media/street-furniture' }) }}" class="fcard fcard--c"
                   data-reveal>
                    <div class="fcard__img" style="background-image:url('{{ asset('images/city.jpg') }}')"></div>
                    <span class="fcard__tag">Пешеходы</span>
                    <h3>Сити-формат</h3>
                    <p>Световой лайтбокс на уровне глаз.</p>
                    <span class="fcard__link">Подробнее <span class="arr">→</span></span>
                </a>
                <a href="{{ path('app_map_app') }}" class="fcard fcard--d" data-reveal>
                    <div class="fcard__img" style="background-image:url('{{ asset('images/bilboard.jpg') }}')"></div>
                    <span class="fcard__tag">Классика OOH</span>
                    <h3>Билборды 6×3 м</h3>
                    <p>Отдельностоящая конструкция с двумя полями. Сторона A — по ходу потока, B — встречная. База
                        городской кампании.</p>
                    <span class="fcard__link">На карте <span class="arr">→</span></span>
                </a>
            </div>
        </div>
    </section>

    {# TICKER #}
    {% set ticker_items = [
        { type: 'format', label: 'Суперсайты', tag: 'Охват', color: 'var(--color-tint-blue)', tc: 'var(--color-blue)', href: path('app_site_page', { path: 'media/supersites' }) },
        { type: 'stat',   label: '15 лет на рынке OOH' },
        { type: 'format', label: 'Digital-экраны', tag: 'Динамика', color: 'var(--color-tint-coral)', tc: 'var(--color-coral)', href: path('app_site_page', { path: 'media/digital' }) },
        { type: 'stat',   label: 'Живая карта конструкций' },
        { type: 'format', label: 'Сити-формат', tag: 'Пешеходы', color: 'var(--color-tint-mint)', tc: 'var(--color-free)', href: path('app_site_page', { path: 'media/street-furniture' }) },
        { type: 'stat',   label: 'Бронирование в один клик' },
        { type: 'format', label: 'Билборды 6×3 м', tag: 'Классика', color: 'var(--color-tint-amber)', tc: 'var(--color-hold)', href: path('app_site_page', { path: 'media/billboards' }) },
        { type: 'stat',   label: 'Фотоотчёт по каждой точке' },
        { type: 'format', label: 'Наружная реклама', tag: 'Улан-Удэ', color: 'var(--color-tint-blue)', tc: 'var(--color-blue)', href: path('app_map_app') },
        { type: 'stat',   label: 'Макет и запуск за 5 дней' },
    ] %}

    <div class="ticker-wrap my-0 py-0" aria-hidden="true">
        <div class="ticker-track">
            {# дублируем дважды для бесшовного loop #}
            {% for _ in 1..2 %}
                {% for item in ticker_items %}
                    <span class="ticker-item">
                        {% if item.type == 'format' %}
                            <a href="{{ item.href }}">
                                <span class="t-pill"
                                      style="background:{{ item.color }};color:{{ item.tc }}">{{ item.tag }}</span>
                                {{ item.label }}
                            </a>
                        {% else %}
                            <span class="t-dot"></span>
                            {{ item.label }}
                        {% endif %}
                    </span>
                {% endfor %}
            {% endfor %}
        </div>
    </div>

    {# HOW #}
    <section class="u-section" id="how">
        <div class="u-wrap">
            <div class="mb-12 max-w-[48ch]" data-reveal>
                <h2 class="u-sec-title">От брифа до <em class="u-grad not-italic">фотоотчёта</em></h2>
                <p class="u-sec-lead">Прозрачный путь без потерянных писем: вы видите занятость, мы держим сроки.</p>
            </div>
            <div class="grid gap-[18px] md:grid-cols-3">
                <div class="h-step u-card p-7" data-reveal>
                    <div class="h-step__n">1</div>
                    <h3 class="mt-4 text-xl font-extrabold">Подбор и бронь</h3>
                    <p class="mt-2 text-[.96rem] text-[var(--color-muted)]">Фильтруете по типу, району и датам на карте,
                        добавляете стороны в корзину и бронируете.</p></div>
                <div class="h-step u-card p-7" data-reveal>
                    <div class="h-step__n">2</div>
                    <h3 class="mt-4 text-xl font-extrabold">Макет и запуск</h3>
                    <p class="mt-2 text-[.96rem] text-[var(--color-muted)]">Адаптируем креатив под каждый формат и
                        площадку. Старт обычно за 2–5 рабочих дней.</p></div>
                <div class="h-step u-card p-7" data-reveal>
                    <div class="h-step__n">3</div>
                    <h3 class="mt-4 text-xl font-extrabold">Контроль и отчёт</h3>
                    <p class="mt-2 text-[.96rem] text-[var(--color-muted)]">Подтверждаем размещение фотоотчётом по
                        каждой конструкции и сопровождаем кампанию.</p></div>
            </div>
        </div>
    </section>

    {# MAP CTA #}
    <section class="u-section">
        <div class="u-wrap">
            <div class="u-grad-panel relative overflow-hidden" data-reveal>
                <div class="grid items-center gap-10 p-[clamp(2.4rem,4vw,3.6rem)] lg:grid-cols-[1.1fr_.9fr]">
                    <div>
                        <h2 class="text-[clamp(1.9rem,4vw,3rem)] font-extrabold leading-[1.08] tracking-[-.02em]">Город
                            уже на карте</h2>
                        <p class="mt-4 max-w-[42ch] text-white/85">Интерактивный каталог конструкций: фильтры по формату
                            и району, занятость по датам, бронирование и корзина заявки.</p>
                        <div class="mt-7 flex flex-wrap gap-3">
                            <a href="{{ path('app_map_app') }}" class="u-btn"
                               style="background:#fff;color:var(--color-ink)">Открыть карту <span
                                    class="arr">→</span></a>
                            <a href="tel:+79148300553" class="u-btn u-btn--ghost">+7 (914) 830-05-53</a>
                        </div>
                    </div>
                    <div class="rounded-[20px] border border-white/20 bg-white/10 p-[18px] backdrop-blur-md">
                        <div class="flex items-center justify-between border-b border-white/15 py-2.5 text-[.94rem]">
                            <span>Билборд · ул. Ленина</span><span class="font-bold text-[#9BF7C8]">Свободна</span>
                        </div>
                        <div class="flex items-center justify-between border-b border-white/15 py-2.5 text-[.94rem]">
                            <span>Суперсайт · Трасса М55</span><span class="font-bold text-[#FFD0C6]">До 14.07</span>
                        </div>
                        <div class="flex items-center justify-between border-b border-white/15 py-2.5 text-[.94rem]">
                            <span>Digital · ТЦ People’s Park</span><span
