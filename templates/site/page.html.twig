{% extends 'base.html.twig' %}

{% block title %}{{ page_title }} — БМС{% endblock %}

{% block body %}
    <header class="site-page-hero relative overflow-hidden border-b border-gray-200 bg-gradient-to-br from-[#05299E] via-[#041d6b] to-[#0d1117] text-white">
        <div class="pointer-events-none absolute inset-0 opacity-90 site-page-hero-grid"></div>
        <div class="pointer-events-none absolute -right-24 top-0 h-[min(80vw,520px)] w-[min(80vw,520px)] rounded-full bg-[#e85d4c]/25 blur-3xl"></div>
        <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
            <nav class="ooh-reveal mb-8 text-[11px] font-semibold uppercase tracking-[0.2em] text-white/55" aria-label="Навигация по разделу">
                <a href="{{ path('app_homepage') }}" class="transition hover:text-white">Главная</a>
                <span class="mx-2 text-white/35" aria-hidden="true">/</span>
                <span class="text-white/80">{{ section_label }}</span>
            </nav>
            <p class="ooh-reveal home-display text-xs font-semibold uppercase tracking-[0.35em] text-[#e85d4c]" style="--ooh-delay: 60ms">
                {{ section_label }}
            </p>
            <h1 class="ooh-reveal home-display home-display-tight mt-4 max-w-4xl text-[clamp(2rem,5vw,3.25rem)] font-bold uppercase leading-[1.05] tracking-tight" style="--ooh-delay: 120ms">
                {{ page_title }}
            </h1>
            <p class="ooh-reveal mt-6 max-w-2xl text-base leading-relaxed text-white/70" style="--ooh-delay: 200ms">
                Материалы раздела можно заменить на финальные тексты и медиа — структура страницы и URL останутся прежними.
            </p>
            <p class="ooh-reveal mt-8 text-sm text-white/45" style="--ooh-delay: 260ms">
                <span class="text-white/55">Адрес:</span>
                <code class="ml-2 rounded bg-white/10 px-2 py-1 font-mono text-xs text-white/90">/site/{{ path }}</code>
            </p>
        </div>
    </header>

    <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:flex lg:gap-16 lg:px-8 lg:py-20">
        <article class="ooh-reveal max-w-none lg:flex-1">
            <h2 class="home-display text-lg font-bold uppercase tracking-wide text-gray-900">Содержание раздела</h2>
            <p class="mt-5 text-base leading-relaxed text-gray-600">
                Здесь удобно разместить описание услуг, преимущества, процесс работы и призыв к действию. При необходимости добавьте формы, встраиваемое видео или блоки с цифрами — вёрстка уже совместима с анимациями появления при прокрутке (класс <code class="rounded bg-gray-100 px-1 text-sm">ooh-reveal</code>).
            </p>
            <div class="mt-10 grid gap-4 sm:grid-cols-2">
                <div class="ooh-lift rounded-lg border border-gray-200 bg-gray-50/80 p-6 transition hover:border-[#05299E]/25 hover:shadow-md">
                    <p class="text-xs font-semibold uppercase tracking-wider text-[#05299E]">Для агентств</p>
                    <p class="mt-2 text-sm text-gray-600">Медиапланы, бронирование и отчётность в одном контуре.</p>
                </div>
                <div class="ooh-lift rounded-lg border border-gray-200 bg-gray-50/80 p-6 transition hover:border-[#05299E]/25 hover:shadow-md">
                    <p class="text-xs font-semibold uppercase tracking-wider text-[#e85d4c]">Для брендов</p>
                    <p class="mt-2 text-sm text-gray-600">Подбор форматов и креатив под реальные конструкции.</p>
                </div>
            </div>
            <p class="mt-10 text-sm text-gray-500">
                Нужна карта инвентаря — переходите в
                <a href="{{ path('app_map_app') }}" class="font-semibold text-[#05299E] underline-offset-2 hover:underline">подбор площадок</a>.
            </p>
        </article>

        {% if related_pages is not empty %}
            <aside class="ooh-reveal mt-14 w-full shrink-0 border-t border-gray-100 pt-10 lg:mt-0 lg:w-72 lg:border-l lg:border-t-0 lg:pl-10 lg:pt-0" style="--ooh-delay: 100ms">
                <h3 class="home-display text-xs font-bold uppercase tracking-[0.2em] text-gray-400">В этом разделе</h3>
                <ul class="mt-5 space-y-1">
                    {% for item in related_pages %}
                        <li>
                            <a href="{{ path('app_site_page', { path: item.path }) }}" class="group flex items-center justify-between gap-2 rounded-md py-2.5 pl-1 pr-2 text-sm font-medium text-gray-800 transition hover:bg-[#05299E]/5 hover:text-[#05299E]">
                                <span>{{ item.label }}</span>
                                <span class="text-gray-300 transition group-hover:translate-x-0.5 group-hover:text-[#05299E]" aria-hidden="true">→</span>
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </aside>
        {% endif %}
    </div>
{% endblock %}
