{% extends 'base.html.twig' %}

{% block title %}Контакты — БМС{% endblock %}

{% block body %}
    {# Крошки, заголовок, блоки контактов #}
    <div class="contact-page bg-white">
        <section class="border-b border-gray-100 bg-[#fafafa]">
            <div class="mx-auto max-w-[1200px] px-4 py-10 sm:px-6 sm:py-14 lg:px-10 lg:py-16">
                <nav class="contact-breadcrumb home-display" aria-label="Хлебные крошки">
                    <a href="{{ path('app_homepage') }}">Главная</a>
                    <span class="mx-2 text-gray-300" aria-hidden="true">/</span>
                    <span class="text-gray-500">Контакты</span>
                </nav>
                <h1 class="contact-title home-display mt-8">Контакты</h1>
                <p class="contact-lead mt-6">
                    Свяжитесь с нами по вопросам размещения, бронирования конструкций и сотрудничества.
                    Ответим в рабочие дни, поможем подобрать формат и локации под вашу кампанию.
                </p>
            </div>
        </section>

        <section class="mx-auto max-w-[1200px] px-4 py-12 sm:px-6 sm:py-16 lg:px-10">
            <div class="mx-auto max-w-3xl space-y-6">
                    <article class="contact-card shadow-sm">
                        <p class="contact-card__label home-display">Офис</p>
                        <h2 class="contact-card__title home-display">Головной офис</h2>
                        <div class="contact-card__body">
                            <dl class="contact-dl">
                                <div>
                                    <dt class="contact-dt home-display">Адрес</dt>
                                    <dd class="contact-dd">670000, Республика Бурятия, г. Улан-Удэ, ул. Ленина, 35</dd>
                                </div>
                                <div>
                                    <dt class="contact-dt home-display">Телефон</dt>
                                    <dd class="contact-dd">
                                        <a href="tel:+79148300553">+7(914)830-05-53</a>
                                    </dd>
                                </div>
                                <div>
                                    <dt class="contact-dt home-display">E-mail</dt>
                                    <dd class="contact-dd">
                                        <a href="mailto:n.batueva@domline.ru">n.batueva@domline.ru</a>
                                    </dd>
                                </div>
                                <div>
                                    <dt class="contact-dt home-display">Режим работы</dt>
                                    <dd class="contact-dd">Пн–Пт, 9:00–18:00 (местное время)</dd>
                                </div>
                            </dl>
                        </div>
                    </article>

                    <article class="contact-card shadow-sm">
                        <p class="contact-card__label home-display">Отделы</p>
                        <h2 class="contact-card__title home-display">Размещение и медиапланирование</h2>
                        <div class="contact-card__body">
                            <p>Заявки на размещение, подбор сетки, согласование дат и макетов.</p>
                            <p class="mt-3">
                                <a href="mailto:n.batueva@domline.ru">n.batueva@domline.ru</a>
                            </p>
                        </div>
                    </article>

                    <article class="contact-card shadow-sm">
                        <h2 class="contact-card__title home-display">Пресс-служба</h2>
                        <div class="contact-card__body">
                            <p>Запросы СМИ, комментарии для публикаций, материалы для прессы.</p>
                            <p class="mt-3">
                                <a href="mailto:n.batueva@domline.ru">n.batueva@domline.ru</a>
                            </p>
                        </div>
                    </article>
            </div>

            <div class="mt-12 border-t border-gray-100 pt-10 text-center">
                <a href="{{ path('app_map_app') }}" class="home-display inline-flex min-h-[48px] min-w-[220px] items-center justify-center bg-[#05299E] px-8 text-sm font-semibold uppercase tracking-wider text-white transition hover:bg-[#041d6b]">
                    Карта конструкций
                </a>
            </div>
        </section>
    </div>
{% endblock %}
