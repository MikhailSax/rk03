{% extends 'base.html.twig' %}

{% block title %}Контакты — РК03{% endblock %}

{% block body %}
    <section class="u-section">
        <div class="u-wrap">
            <nav class="text-[.72rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-muted)]"
                 aria-label="Хлебные крошки" data-reveal>
                <a href="{{ path('app_homepage') }}" class="transition hover:text-[var(--color-ink)]">Главная</a>
                <span class="mx-2 opacity-40">/</span><span>Контакты</span>
            </nav>
            <h1 class="u-sec-title mt-7" data-reveal>Контакты</h1>
            <p class="u-sec-lead" data-reveal>
                Свяжитесь с нами по вопросам размещения, бронирования конструкций и сотрудничества.
                Ответим в рабочие дни, поможем подобрать формат и локации под вашу кампанию.
            </p>

            <div class="mt-10 grid gap-6 lg:grid-cols-[1.3fr_1fr]">
                <article class="u-card p-6 sm:p-8" data-reveal>
                    <span class="u-pill" style="background:var(--color-tint-coral);color:var(--color-coral)">Офис</span>
                    <h2 class="mt-3 text-xl font-extrabold">Головной офис</h2>
                    <dl class="mt-6 grid gap-5 sm:grid-cols-2">
                        <div>
                            <dt class="text-[.72rem] font-bold uppercase tracking-[0.12em] text-[var(--color-muted)]">
                                Адрес
                            </dt>
                            <dd class="mt-1">670000, Республика Бурятия, г. Улан-Удэ, ул. Ленина, 35</dd>
                        </div>
                        <div>
                            <dt class="text-[.72rem] font-bold uppercase tracking-[0.12em] text-[var(--color-muted)]">
                                Телефон
                            </dt>
                            <dd class="mt-1"><a href="tel:+79834366777"
                                                class="font-semibold text-[var(--color-blue)] hover:underline">8 (983)
                                    436-67-77</a></dd>
                        </div>
                        <div>
                            <dt class="text-[.72rem] font-bold uppercase tracking-[0.12em] text-[var(--color-muted)]">
                                E-mail
                            </dt>
                            <dd class="mt-1"><a href="mailto:rk@domline.ru"
                                                class="font-semibold text-[var(--color-blue)] hover:underline">rk@domline.ru</a>
                            </dd>
                        </div>
                        <div>
                            <dt class="text-[.72rem] font-bold uppercase tracking-[0.12em] text-[var(--color-muted)]">
                                Режим работы
                            </dt>
                            <dd class="mt-1">Пн–Пт, 9:00–18:00 (местное время)</dd>
                        </div>
                    </dl>
                </article>

                <div class="flex flex-col gap-6">
                    <article class="u-card p-6 sm:p-8" data-reveal>
                        <h2 class="text-xl font-extrabold">Размещение и медиапланирование</h2>
                        <p class="mt-3 text-[var(--color-muted)]">Заявки на размещение, подбор сетки, согласование дат и
                            макетов.</p>
                        <a href="mailto:rk@domline.ru"
                           class="mt-3 inline-block font-semibold text-[var(--color-blue)] hover:underline">rk@domline.ru</a>
                    </article>
                    <article class="u-card p-6 sm:p-8" data-reveal>
                        <h2 class="text-xl font-extrabold">Пресс-служба</h2>
                        <p class="mt-3 text-[var(--color-muted)]">Запросы СМИ, комментарии для публикаций, материалы для
                            прессы.</p>
                        <a href="mailto:rk@domline.ru"
                           class="mt-3 inline-block font-semibold text-[var(--color-blue)] hover:underline">rk@domline.ru</a>
                    </article>
                </div>
            </div>

            <div class="mt-12 text-center" data-reveal>
                <a href="{{ path('app_map_app') }}" class="u-btn u-btn--blue">Карта конструкций <span
                        class="arr">→</span></a>
            </div>
        </div>
    </section>
{% endblock %}
