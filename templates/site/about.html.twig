{% extends 'base.html.twig' %}

{% block title %}О компании — РК03{% endblock %}

{% block head_extra %}
    <meta name="description" content="РК03 (Рекламные конструкции 03) — оператор наружной рекламы: форматы, карта конструкций, команда и устойчивое развитие." />
{% endblock %}

{% set about_tile_blurb = {
    'about/leadership': 'Руководство и контакты по ключевым направлениям работы.',
    'about/partners': 'Совместные проекты и долгосрочные партнёрские программы.',
    'about/esg': 'Экология, безопасность и социальная ответственность.',
    'about/investors': 'Раскрытие информации и материалы для инвесторов.',
    'about/real-estate': 'Площадки, аренда и развитие рекламной инфраструктуры.',
} %}

{% block body %}
    <section class="u-section">
        <div class="u-wrap">
            {# hero #}
            <div class="u-grad-panel relative overflow-hidden p-8 sm:p-12 lg:p-16" data-reveal>
                <nav class="text-[.72rem] font-semibold uppercase tracking-[0.16em] text-white/60" aria-label="Хлебные крошки">
                    <a href="{{ path('app_homepage') }}" class="transition hover:text-white">Главная</a>
                    <span class="mx-2 opacity-40">/</span><span class="text-white/85">О компании</span>
                </nav>
                <p class="mt-7 text-[.72rem] font-bold uppercase tracking-[0.22em] text-white/70">О компании</p>
                <h1 class="mt-3 max-w-4xl text-[clamp(1.8rem,4.5vw,3rem)] font-extrabold leading-[1.1] tracking-[-.02em]">
                    Соединяем бренды и их аудиторию с помощью наружной рекламы
                </h1>
                <p class="mt-6 max-w-2xl text-white/85">
                    <b class="font-semibold text-white">РК03 (Рекламные конструкции 03)</b> — группа независимых операторов наружной рекламы.
                    Большая сеть конструкций, лучшие места в городе, сервис и комфортные условия для любого бизнеса. Развиваем бизнес вместе с вами уже более 15 лет.
                </p>
            </div>

            {# stats #}
            <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" data-reveal>
                {% set stats = [
                    { v: '15', l: 'лет опыта в наружной рекламе и работе с локальными брендами' },
                    { v: 'Единая карта', l: 'актуальный каталог, бронирование и контроль кампаний' },
                    { v: 'Полный цикл', l: 'бриф, производство, монтаж, сопровождение и фотоотчёты' },
                    { v: 'Измеримость', l: 'прозрачная отчётность и понятные сроки запуска' }
                ] %}
                {% for s in stats %}
                    <div class="u-card p-6">
                        <p class="font-[var(--font-display)] font-bold text-[var(--color-blue)] {{ s.v|length > 3 ? 'text-xl' : 'text-4xl' }}">{{ s.v }}</p>
                        <p class="mt-2 text-[.86rem] text-[var(--color-muted)]">{{ s.l }}</p>
                    </div>
                {% endfor %}
            </div>

            {# кто мы #}
            <div class="mt-12 grid items-center gap-10 lg:grid-cols-2" data-reveal>
                <figure class="m-0 overflow-hidden rounded-[var(--radius-card)] shadow-[var(--shadow-card)]">
                    <img src="{{ asset('images/digital.png') }}" alt="Примеры наружных форматов в городе" class="h-full w-full object-cover" width="960" height="640" loading="lazy" decoding="async">
                </figure>
                <div>
                    <h2 class="text-2xl font-extrabold tracking-tight">Кто мы</h2>
                    <div class="mt-5 space-y-4 text-[var(--color-muted)]">
                        <p>Развиваем наружную рекламу там, где она даёт максимальный контакт с аудиторией: на магистралях, в транспортных коридорах и ключевых точках города. Работаем с агентствами и прямыми рекламодателями — от разовых размещений до долгосрочных контрактов.</p>
                        <p>Наша цель — сделать закупку OOH предсказуемой: понятные форматы, честные сроки, аккуратное производство креатива и сопровождение на площадке.</p>
                    </div>
                    <a href="{{ path('app_site_page', { path: 'formats' }) }}" class="u-btn u-btn--soft mt-7">Смотреть форматы <span class="arr">→</span></a>
                </div>
            </div>

            {# разделы #}
            {% if related_pages is defined and related_pages is not empty %}
                <div class="mt-14" data-reveal>
                    <h2 class="text-2xl font-extrabold tracking-tight">Компания</h2>
                    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                        {% for item in related_pages %}
                            <a href="{{ path('app_site_page', { path: item.path }) }}" class="u-card group flex flex-col p-6 transition hover:-translate-y-1 hover:shadow-[var(--shadow-card)]">
                                <span class="text-[.66rem] font-bold uppercase tracking-[0.14em] text-[var(--color-coral)]">Подробнее</span>
                                <span class="mt-2 text-lg font-extrabold">{{ item.label }}</span>
                                <span class="mt-2 flex-1 text-[.88rem] text-[var(--color-muted)]">{{ about_tile_blurb[item.path]|default('Материалы раздела — в разработке.') }}</span>
                                <span class="mt-4 inline-flex items-center gap-1.5 text-[.82rem] font-semibold text-[var(--color-blue)]">Перейти <span class="transition group-hover:translate-x-0.5">→</span></span>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# таймлайн #}
            <div class="mt-14 grid gap-10 lg:grid-cols-[5fr_7fr]" data-reveal>
                <div>
                    <h2 class="text-2xl font-extrabold tracking-tight">Развитие</h2>
                    <p class="mt-4 text-[var(--color-muted)]">Вехи компании: выход на рынок, запуск digital-направления, масштабирование сети.</p>
                </div>
                <ol class="relative space-y-0">
                    {% set milestones = [
                        { y: 'Старт', t: 'Фокус на классических билбордах и городских форматах в регионе.' },
                        { y: 'Цифровизация', t: 'Карта конструкций, онлайн-подбор площадок и прозрачная занятость.' },
                        { y: 'Сегодня', t: 'Комплексные кампании: классика + digital OOH, отчётность и сопровождение.' }
                    ] %}
                    {% for m in milestones %}
                        <li class="relative border-l-2 border-[rgba(13,19,32,.1)] pb-6 pl-6 {{ loop.last ? '!border-transparent pb-0' : '' }}">
                            <span class="absolute -left-[5px] top-1.5 h-2 w-2 rounded-full bg-[var(--color-coral)]"></span>
                            <p class="text-[.74rem] font-bold uppercase tracking-[0.1em] text-[var(--color-blue)]">{{ m.y }}</p>
                            <p class="mt-1.5 text-[var(--color-muted)]">{{ m.t }}</p>
                        </li>
                    {% endfor %}
                </ol>
            </div>

            {# cta #}
            <div class="u-grad-panel mt-14 flex flex-col gap-6 p-8 sm:p-10 md:flex-row md:items-center md:justify-between" data-reveal>
                <div>
                    <h2 class="text-xl font-extrabold tracking-tight sm:text-2xl">Подберём площадки под кампанию</h2>
                    <p class="mt-2 max-w-xl text-white/85">Откройте карту или свяжитесь с командой — подготовим медиаплан и смету.</p>
                </div>
                <div class="flex flex-wrap gap-3">
                    <a href="{{ path('app_map_app') }}" class="u-btn" style="background:#fff;color:var(--color-ink)">Карта конструкций</a>
                    <a href="{{ path('app_site_page', { path: 'contact' }) }}" class="u-btn u-btn--ghost">Контакты</a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
