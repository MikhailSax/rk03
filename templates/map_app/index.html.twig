{% extends 'base.html.twig' %}

{% block title %}Рекламные конструкции — карта и каталог{% endblock %}

{% block body %}
    <div
        id="map-app"
        class="map-app-root flex min-h-[calc(100dvh-4rem)] flex-col bg-[#ececee] lg:h-[calc(100dvh-4rem)]"
        data-filters-url="{{ path('api_filters') }}"
        data-advertisements-url="{{ path('api_advertisements_list') }}"
        data-orders-url="{{ path('api_orders_create') }}"
        data-cart-url="{{ path('api_cart_get') }}"
        data-is-authenticated="{{ app.user ? '1' : '0' }}"
        data-user-id="{{ app.user ? app.user.id : '' }}"
        data-user-name="{{ app.user ? (app.user.firstName ~ ' ' ~ (app.user.lastName ?? ''))|trim : '' }}"
        data-user-phone="{{ app.user ? app.user.phone : '' }}"
        data-user-email="{{ app.user ? app.user.userIdentifier : '' }}"
    >
        <div id="initial-spinner"
             class="flex min-h-[50vh] flex-col items-center justify-center bg-[#05299E] text-white">
            <div class="h-10 w-10 animate-spin rounded-full border-4 border-white/20 border-t-[#e85d4c]"></div>
            <p class="site-header-font mt-4 text-xs font-semibold uppercase tracking-[0.2em] text-white/70">Загрузка
                каталога…</p>
        </div>
    </div>
{% endblock %}
