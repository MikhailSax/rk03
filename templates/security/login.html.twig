{% extends 'layout/auth_centered.html.twig' %}
{% import 'macros/account_ui.html.twig' as ui %}

{% block title %}Вход в систему{% endblock %}

{% block auth_eyebrow %}Вход в аккаунт{% endblock %}

{% block auth_inner %}
    <div class="text-center">
        <h1 class="{{ ui.auth_title_class() }}">Вход</h1>
        <p class="{{ ui.auth_subtitle_class() }}">
            Продолжите в <span class="font-semibold text-[#05299E]">РК03</span> <span class="text-gray-600">(Рекламные Конструкции 03)</span>
        </p>
    </div>

    <div class="mt-8">
        {% include 'components/_account_flashes.html.twig' with { keys: ['error', 'success'] } only %}
    </div>

    {% if app.user %}
        <div class="mt-6 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-4 text-center text-sm text-emerald-800">
            Вы уже вошли как {{ app.user.userIdentifier }},
            <a href="{{ path('app_logout') }}" class="font-semibold text-[#05299E] underline-offset-2 hover:underline">Выйти</a>
        </div>
    {% else %}
        <form class="mt-8 space-y-5" action="{{ path('app_login') }}" method="POST">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" />

            <div>
                <label for="email" class="{{ ui.label_class() }}">Почта</label>
                <input id="email" name="_username" type="email" autocomplete="email" required autofocus
                       class="{{ ui.input_class() }}"
                       value="{{ last_username }}" />
            </div>

            <div>
                <label for="password" class="{{ ui.label_class() }}">Пароль</label>
                <input id="password" name="_password" type="password" autocomplete="current-password" required
                       class="{{ ui.input_class() }}" />
            </div>

            {% if error %}
                <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <div class="pt-1">
                <button type="submit" class="{{ ui.btn_primary_full() }}">
                    Войти
                </button>
            </div>
        </form>

        <div class="relative my-8">
            <div class="absolute inset-0 flex items-center">
                <div class="w-full border-t border-gray-200"></div>
            </div>
            <div class="relative flex justify-center text-xs uppercase tracking-[0.12em] text-gray-400">
                <span class="bg-white px-3">или</span>
            </div>
        </div>

        <div class="flex flex-col gap-3">
            <a href="{{ path('connect_yandex') }}"
               class="flex items-center justify-center gap-3 rounded-lg border border-gray-300 bg-white px-4 py-3.5 text-sm font-medium text-gray-800 shadow-sm transition hover:border-[#05299E]/40 hover:bg-gray-50/80">
                <img src="{{ asset('images/orig.png') }}" alt="" class="h-5 w-auto" width="20" height="20">
                <span>Войти через Яндекс</span>
            </a>
        </div>

        <p class="mt-8 text-center text-sm text-gray-600">
            Нет аккаунта?
            <a href="{{ path('app_register') }}" class="{{ ui.link_accent_class() }}">Регистрация</a>
        </p>
    {% endif %}
{% endblock %}
