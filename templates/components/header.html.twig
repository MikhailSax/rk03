{# =====================================================================
   Шапка (Фаза 1). Плавающая «пилюля», светлая, blur.
   Сохранены id #mobile-menu / #mobile-menu-button и .dropdown — под текущий
   assets/js/header.js. Маршруты и логика app.user не изменены.
   ===================================================================== #}
{% set header_nav = site_header_nav() %}

<div class="sticky top-0 z-50 pt-4">
    <header class="u-wrap">
        <div class="flex items-center justify-between gap-4 rounded-full border border-white/70 bg-white/75 px-5 py-2.5 shadow-[var(--shadow-soft)] backdrop-blur-xl">

            {# бренд #}
            <a href="{{ path('app_homepage') }}" class="flex shrink-0 items-center gap-2" aria-label="Рекламные конструкции 03">
                <img src="{{ asset('images/header-rk-logo.png') }}" alt="РК03" width="280" height="117" class="h-8 w-auto sm:h-9" decoding="async">
                <span class="sr-only">Рекламные конструкции 03</span>
            </a>

            {# десктоп-навигация #}
            <nav class="hidden items-center gap-7 text-[.95rem] font-semibold text-[var(--color-muted)] lg:flex" aria-label="Основное меню">
                <a href="{{ path('app_site_page', { path: 'formats' }) }}" class="transition hover:text-[var(--color-ink)]">Форматы</a>
                <a href="{{ path('app_map_app') }}" class="transition hover:text-[var(--color-ink)]">Карта конструкций</a>
                <a href="{{ path('app_site_page', { path: 'contact' }) }}" class="transition hover:text-[var(--color-ink)]">Контакты</a>
                <a href="{{ path('app_site_page', { path: 'about' }) }}" class="transition hover:text-[var(--color-ink)]">О нас</a>
            </nav>

            {# правый блок #}
            <div class="flex shrink-0 items-center gap-2 sm:gap-3">
                <a href="{{ path('app_cart') }}" class="hidden rounded-full px-3 py-2 text-sm font-semibold text-[var(--color-muted)] transition hover:bg-[var(--color-bg-2)] hover:text-[var(--color-ink)] lg:inline-flex">Корзина</a>

                {% if app.user %}
                    <a href="{{ path('profile') }}" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[var(--color-bg-2)] text-[var(--color-ink)] transition hover:bg-[var(--color-tint-blue)]" aria-label="Личный кабинет">
                        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                    </a>
                    <a href="{{ path('app_map_app') }}" class="u-btn u-btn--blue hidden lg:inline-flex">Карта конструкций <span class="arr">→</span></a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="hidden px-3 py-2 text-sm font-semibold text-[var(--color-ink)] sm:inline-flex">Войти</a>
                    <a href="{{ path('app_map_app') }}" class="u-btn u-btn--blue hidden lg:inline-flex">Карта конструкций <span class="arr">→</span></a>
                {% endif %}

                <button id="mobile-menu-button" type="button" class="rounded-full p-2 text-[var(--color-ink)] transition hover:bg-[var(--color-bg-2)] lg:hidden" aria-expanded="false" aria-controls="mobile-menu" aria-label="Открыть меню">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </button>
            </div>
        </div>

        {# мобильное меню (id сохранён под header.js: toggle .hidden) #}
        <div id="mobile-menu" class="hidden lg:hidden">
            <div class="mt-2 rounded-[var(--radius-card)] border border-[var(--line,rgba(13,19,32,.08))] bg-white p-4 shadow-[var(--shadow-card)]">
                <ul class="space-y-1 text-base font-semibold">
                    <li><a href="{{ path('app_site_page', { path: 'formats' }) }}" class="block rounded-xl px-3 py-2.5 transition hover:bg-[var(--color-bg-2)]">Форматы</a></li>
                    <li><a href="{{ path('app_map_app') }}" class="block rounded-xl px-3 py-2.5 transition hover:bg-[var(--color-bg-2)]">Карта конструкций</a></li>
                    <li><a href="{{ path('app_cart') }}" class="block rounded-xl px-3 py-2.5 transition hover:bg-[var(--color-bg-2)]">Корзина</a></li>
                    <li><a href="{{ path('app_site_page', { path: 'contact' }) }}" class="block rounded-xl px-3 py-2.5 transition hover:bg-[var(--color-bg-2)]">Контакты</a></li>
                    <li><a href="{{ path('app_site_page', { path: 'about' }) }}" class="block rounded-xl px-3 py-2.5 transition hover:bg-[var(--color-bg-2)]">О нас</a></li>
                </ul>


                <div class="mt-4 flex flex-col gap-2">
                    {% if app.user %}
                        <a href="{{ path('profile') }}" class="u-btn u-btn--soft justify-center">Личный кабинет</a>
                        <a href="{{ path('app_logout') }}" class="u-btn u-btn--primary justify-center">Выйти</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="u-btn u-btn--soft justify-center">Вход</a>
                        <a href="{{ path('app_register') }}" class="u-btn u-btn--blue justify-center">Регистрация</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </header>
</div>
