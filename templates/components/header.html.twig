{% set header_nav = site_header_nav() %}
{% set chevron %}
    <svg class="site-header-chevron ml-0.5 h-2.5 w-2.5 shrink-0 opacity-75" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true"><path d="M6 8L1 3h10z"/></svg>
{% endset %}

{# Верхняя плашка по макету Figma (SVG «Верхняя плашка 2»): #05299E, навигация ~22px, кнопка «Вход» — белая капсула. #}
<header class="site-header figma-top-bar sticky top-0 z-50 border-b border-white/10 bg-[#05299E] text-white shadow-sm header">
    <div class="mx-auto flex max-w-[1600px] flex-wrap items-center justify-between gap-x-4 gap-y-4 px-4 py-5 sm:px-6 lg:flex-nowrap lg:gap-x-6 lg:px-10 lg:py-8">
        <a href="{{ path('app_homepage') }}" class="logo group flex shrink-0 items-center gap-3 leading-none" aria-label="БМС, Бурятия Медиа Сервис — на главную">
            <img src="{{ asset('images/header-bms-logo.png') }}" alt="БМС — Бурятия Медиа Сервис" width="280" height="117" class="h-9 w-auto sm:h-10 md:h-11" decoding="async"/>
            <span class="sr-only">БМС, Бурятия Медиа Сервис</span>
        </a>

        <nav class="figma-top-bar__nav order-3 hidden w-full items-center justify-center gap-x-4 text-base font-normal leading-none text-white/95 lg:order-none lg:flex lg:w-auto lg:flex-1 lg:gap-x-5 lg:text-[1.15rem] xl:gap-x-7 xl:text-[1.22rem] 2xl:gap-x-9" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;" aria-label="Основное меню">
            <a href="{{ path('app_site_page', { path: 'formats' }) }}" class="whitespace-nowrap transition hover:text-white">Форматы</a>
            <a href="{{ path('app_map_app') }}" class="whitespace-nowrap transition hover:text-white">Карта конструкций</a>
            <a href="{{ path('app_site_page', { path: 'contact' }) }}" class="whitespace-nowrap transition hover:text-white">Контакты</a>
{#            <a href="{{ path('app_site_page', { path: 'newsroom' }) }}" class="whitespace-nowrap transition hover:text-white">Акции</a>#}
            <a href="{{ path('app_site_page', { path: 'about' }) }}" class="whitespace-nowrap transition hover:text-white">О нас</a>
        </nav>

        <div class="flex shrink-0 items-center gap-2 sm:gap-3">
            <a href="{{ path('app_map_app') }}" class="figma-top-bar__tool hidden items-center gap-1.5 whitespace-nowrap rounded-md px-2 py-2 text-sm text-white/90 transition hover:bg-white/10 hover:text-white lg:inline-flex" title="Подбор площадок">
                <svg class="h-4 w-4 shrink-0 opacity-85" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                </svg>
                <span class="hidden xl:inline">Карта</span>
            </a>
            <a href="{{ path('app_cart') }}" class="figma-top-bar__tool hidden whitespace-nowrap rounded-md px-2 py-2 text-sm text-white/90 transition hover:bg-white/10 hover:text-white lg:inline-flex">Корзина</a>

            {% if app.user %}
                <a href="{{ path('profile') }}" class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-white text-[#000f08] transition hover:bg-[#f4fff8]" aria-label="Личный кабинет">
                    <svg class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                    </svg>
                </a>
                <a href="{{ path('app_logout') }}" class="hidden text-sm text-white/80 underline-offset-4 hover:text-white hover:underline xl:inline">Выйти</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="inline-flex min-h-[44px] min-w-[6.5rem] items-center justify-center rounded-full bg-white px-6 text-[1.22rem] font-normal text-[#05299E] transition hover:bg-[#f4fff8]" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">Вход</a>
            {% endif %}

            <button id="mobile-menu-button" type="button" class="rounded-full p-2 text-white hover:bg-white/10 lg:hidden" aria-expanded="false" aria-controls="mobile-menu" aria-label="Открыть меню">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </div>
    </div>

    <div id="mobile-menu" class="hidden max-h-[min(100vh-4rem,100dvh)] overflow-y-auto border-t border-white/10 bg-[#041d6b] lg:hidden">
        <div class="mx-auto max-w-[1600px] space-y-1 px-4 py-4">
            <div class="border-b border-white/10 pb-3">
                <p class="site-header-font px-1 text-[10px] font-semibold uppercase tracking-[0.25em] text-white/50">Меню</p>
                <ul class="mt-2 space-y-0.5 text-base">
                    <li><a href="{{ path('app_site_page', { path: 'formats' }) }}" class="block rounded px-1 py-2 text-white/90 hover:bg-white/10">Форматы</a></li>
                    <li><a href="{{ path('app_map_app') }}" class="block rounded px-1 py-2 text-white/90 hover:bg-white/10">Карта конструкций</a></li>
                    <li><a href="{{ path('app_site_page', { path: 'contact' }) }}" class="block rounded px-1 py-2 text-white/90 hover:bg-white/10">Контакты</a></li>
                    <li><a href="{{ path('app_site_page', { path: 'newsroom' }) }}" class="block rounded px-1 py-2 text-white/90 hover:bg-white/10">Акции</a></li>
                    <li><a href="{{ path('app_site_page', { path: 'about' }) }}" class="block rounded px-1 py-2 text-white/90 hover:bg-white/10">О нас</a></li>
                </ul>
            </div>

            <a href="{{ path('app_map_app') }}" class="site-header-font flex items-center gap-2 border-b border-white/10 py-3 text-xs font-semibold uppercase tracking-[0.2em] text-white">
                <svg class="h-4 w-4 opacity-80" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                </svg>
                Подбор площадок
            </a>
            <a href="{{ path('app_cart') }}" class="site-header-font block border-b border-white/10 py-3 text-xs font-semibold uppercase tracking-[0.2em] text-white">Корзина</a>

            {% for section_key, data in header_nav %}
                <div class="border-b border-white/10 py-3">
                    <p class="site-header-font px-1 text-[10px] font-semibold uppercase tracking-[0.25em] text-white/50">{{ data.label }}</p>
                    <ul class="mt-2 space-y-0.5">
                        {% for item in data.items %}
                            <li>
                                <a href="{{ path('app_site_page', { path: item.path }) }}" class="block rounded px-1 py-2 text-sm text-white/90 hover:bg-white/10">
                                    {{ item.label }}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            {% endfor %}

            <div class="pt-4">
                {% if app.user %}
                    <a href="{{ path('profile') }}" class="site-header-font mb-2 block border border-white/35 py-3 text-center text-xs font-semibold uppercase tracking-[0.15em] text-white">Кабинет</a>
                    <a href="{{ path('app_logout') }}" class="site-header-font block bg-[#e85d4c] py-3 text-center text-xs font-semibold uppercase tracking-[0.15em] text-white">Выйти</a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="site-header-font mb-2 block rounded-full border border-white/35 bg-white py-3 text-center text-xs font-semibold uppercase tracking-[0.15em] text-[#05299E]">Вход</a>
                    <a href="{{ path('app_register') }}" class="site-header-font block bg-[#e85d4c] py-3 text-center text-xs font-semibold uppercase tracking-[0.15em] text-white">Регистрация</a>
                {% endif %}
            </div>
        </div>
    </div>
</header>
